{
  "rewrites": [
    {
      "source": "/((?!assets/|icon-|favicon|manifest\\.json|sw\\.js|.*\\.(?:js|css|png|jpg|jpeg|svg|ico|json)).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
